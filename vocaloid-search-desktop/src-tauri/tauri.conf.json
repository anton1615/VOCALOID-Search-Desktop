{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VOCALOID Search Desktop",
  "version": "0.1.0",
  "identifier": "com.vocaloid-search.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": {
        "default-src": [
          "'self'",
          "customprotocol:",
          "asset:",
          "http://localhost:1420",
          "http://127.0.0.1:1420"
        ],
        "script-src": [
          "'self'",
          "'unsafe-eval'",
          "http://localhost:1420",
          "http://127.0.0.1:1420"
        ],
        "style-src": [
          "'self'",
          "'unsafe-inline'",
          "http://localhost:1420",
          "http://127.0.0.1:1420"
        ],
        "connect-src": [
          "'self'",
          "ipc:",
          "http://ipc.localhost",
          "http://localhost:1420",
          "http://127.0.0.1:1420",
          "ws://localhost:1420",
          "ws://127.0.0.1:1420",
          "https://embed.nicovideo.jp"
        ],
        "img-src": [
          "'self'",
          "asset:",
          "http://asset.localhost",
          "data:",
          "blob:",
          "https://secure-dcdn.cdn.nimg.jp",
          "https://nicovideo.cdn.nimg.jp",
          "https://image.nicovideo.jp"
        ],
        "media-src": [
          "'self'",
          "asset:",
          "http://asset.localhost",
          "blob:",
          "https:"
        ],
        "frame-src": [
          "'self'",
          "https://embed.nicovideo.jp"
        ]
      }
    }
  },
  "bundle": {
    "active": false,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
